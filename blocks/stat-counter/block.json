{
    "$schema": "https://schemas.wp.org/wp/6.4/block.json",
    "apiVersion": 3,
    "name": "flairfacilities/stat-counter",
    "version": "1.0.0",
    "title": "Stat Counter",
    "category": "flairfacilities",
    "icon": "chart-line",
    "description": "An animated number counter for displaying statistics.",
    "attributes": {
        "number": {
            "type": "string",
            "default": "15"
        },
        "suffix": {
            "type": "string",
            "default": "+"
        },
        "label": {
            "type": "string",
            "default": "Years of Experience"
        }
    },
    "supports": {
        "color": {
            "background": true,
            "text": true
        },
        "spacing": {
            "padding": true,
            "margin": true
        }
    },
    "editorScript": "file:./index.js",
    "editorStyle": "file:./editor.css",
    "style": "file:./style.css",
    "render": "file:./render.php"
}
