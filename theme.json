{
    "$schema": "https://schemas.wp.org/wp/6.4/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "color": {
            "defaultPalette": false,
            "palette": [
                {
                    "color": "#0f172a",
                    "name": "Dark Navy",
                    "slug": "dark-navy"
                },
                {
                    "color": "#1e3a8a",
                    "name": "Primary Blue",
                    "slug": "primary-blue"
                },
                {
                    "color": "#3b82f6",
                    "name": "Bright Blue",
                    "slug": "bright-blue"
                },
                {
                    "color": "#dc2626",
                    "name": "Accent Red",
                    "slug": "accent-red"
                },
                {
                    "color": "#ea580c",
                    "name": "Accent Orange",
                    "slug": "accent-orange"
                },
                {
                    "color": "#f8fafc",
                    "name": "Off White",
                    "slug": "off-white"
                },
                {
                    "color": "#f1f5f9",
                    "name": "Light Gray",
                    "slug": "light-gray"
                },
                {
                    "color": "#64748b",
                    "name": "Muted Gray",
                    "slug": "muted-gray"
                },
                {
                    "color": "#ffffff",
                    "name": "White",
                    "slug": "white"
                }
            ],
            "gradients": [
                {
                    "gradient": "linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%)",
                    "name": "Navy Gradient",
                    "slug": "navy-gradient"
                },
                {
                    "gradient": "linear-gradient(135deg, #dc2626 0%, #ea580c 100%)",
                    "name": "Fire Gradient",
                    "slug": "fire-gradient"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
                    "name": "Inter",
                    "slug": "inter"
                }
            ],
            "fontSizes": [
                {
                    "name": "Small",
                    "size": "0.875rem",
                    "slug": "small"
                },
                {
                    "name": "Medium",
                    "size": "1.125rem",
                    "slug": "medium"
                },
                {
                    "name": "Large",
                    "size": "1.5rem",
                    "slug": "large"
                },
                {
                    "name": "XL",
                    "size": "2rem",
                    "slug": "xl"
                },
                {
                    "name": "2XL",
                    "size": "2.5rem",
                    "slug": "2xl"
                },
                {
                    "name": "3XL",
                    "size": "3rem",
                    "slug": "3xl"
                },
                {
                    "name": "Hero",
                    "size": "clamp(2.5rem, 5vw, 4rem)",
                    "slug": "hero"
                }
            ]
        },
        "spacing": {
            "units": ["px", "em", "rem", "vh", "vw", "%"],
            "padding": true,
            "margin": true,
            "blockGap": true
        },
        "layout": {
            "contentSize": "800px",
            "wideSize": "1280px"
        },
        "blocks": {
            "core/heading": {
                "typography": {
                    "fontSizes": [],
                    "lineHeight": true
                }
            },
            "core/paragraph": {
                "typography": {
                    "fontSizes": [],
                    "lineHeight": true
                }
            }
        }
    },
    "styles": {
        "color": {
            "background": "#ffffff",
            "text": "#0f172a"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--inter)",
            "fontSize": "1rem",
            "lineHeight": "1.6"
        },
        "elements": {
            "h1": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--hero)",
                    "fontWeight": "800",
                    "lineHeight": "1.1"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--3xl)",
                    "fontWeight": "700",
                    "lineHeight": "1.2"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--2xl)",
                    "fontWeight": "700",
                    "lineHeight": "1.3"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--xl)",
                    "fontWeight": "600",
                    "lineHeight": "1.4"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--primary-blue)"
                }
            }
        }
    },
    "templateParts": [
        {
            "name": "header",
            "area": "header"
        },
        {
            "name": "footer",
            "area": "footer"
        }
    ],
    "customTemplates": [
        {
            "name": "front-page",
            "title": "Front Page",
            "postTypes": ["page"]
        }
    ]
}
